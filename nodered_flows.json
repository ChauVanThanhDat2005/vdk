  {
    "id": "func_auto_reset_servo",
    "type": "function",
    "z": "tab_esp32_iot",
    "name": "Auto Mode & Reset Servo",
    "func": "// Output 0: Send AUTO command\nvar msg1 = {payload: \"AUTO\"};\n\n// Output 1: Send 0 to reset servo immediately  \nvar msg2 = {payload: \"0\"};\n\n// Output 2: Send 0 to reset slider UI after short delay\nvar msg3 = {payload: 0};\nsetTimeout(() => {\n  node.send([null, null, msg3]);\n}, 150);\n\nnode.send([msg1, msg2, null]);\nreturn;",
    "outputs": 3,
    "x": 600, "y": 810,
    "wires": [["mqtt_out_servo"], ["mqtt_out_servo"], ["func_slider_reset"]]
  },
  {
    "id": "func_slider_reset",
    "type": "function",
    "z": "tab_esp32_iot",
    "name": "Update Slider Display",
    "func": "msg.ui_control = {update: {slider_value: 0}};\nnode.send(msg);\nreturn msg;",
    "outputs": 1,
    "x": 750, "y": 810,
    "wires": [["ui_slider_servo"]]
  },
