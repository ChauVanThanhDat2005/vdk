  {
    "id": "func_distance_process",
    "type": "function",
    "z": "tab_esp32_iot",
    "name": "Process Distance",
    "func": "var dist = parseFloat(msg.payload);\nif (isNaN(dist) || dist < 0) return null;\n\nmsg.payload = dist;\n\n// Gắn màu cảnh báo\nif (dist < 10) {\n  msg.color = 'red';\n  msg.alert = 'NGUY HIỂM: Vật quá gần!';\n} else if (dist < 30) {\n  msg.color = 'orange';\n  msg.alert = 'CẢNH BÁO: Vật đang tiếp cận';\n} else {\n  msg.color = 'green';\n  msg.alert = '';\n}\n\nreturn msg;",
    "outputs": 1,
    "x": 360, "y": 80,
    "wires": [["ui_gauge_distance", "func_auto_alert"]]
  },
  {
    "id": "func_pot_process",
    "type": "function",
    "z": "tab_esp32_iot",
    "name": "Process Pot",
    "func": "msg.payload = parseInt(msg.payload);\nif (isNaN(msg.payload)) return null;\nreturn msg;",
    "outputs": 1,
    "x": 360, "y": 160,
    "wires": [["ui_gauge_pot"]]
  },
  {
    "id": "func_btn1_process",
    "type": "function",
    "z": "tab_esp32_iot",
    "name": "Process Button 1",
    "func": "var state = msg.payload;\nif (state === 'PRESSED') {\n  msg.payload = '🔴 Đang nhấn';\n  // Tự động quay về ready sau 500ms\n  setTimeout(() => {\n    msg.payload = '🟢 Sẵn sàng';\n  }, 500);\n} else {\n  msg.payload = '🟢 Sẵn sàng';\n}\nreturn msg;",
    "outputs": 1,
    "x": 360, "y": 240,
    "wires": [["ui_text_btn1"]]
  },
  {
    "id": "func_btn2_process",
    "type": "function",
    "z": "tab_esp32_iot",
    "name": "Process Button 2",
    "func": "var state = msg.payload;\nmsg.payload = (state === 'PRESSED') ? '🔴 Đang nhấn' : '🟢 Nhả ra';\nmsg.pressed = (state === 'PRESSED');\nreturn msg;",
    "outputs": 1,
    "x": 360, "y": 300,
    "wires": [["ui_text_btn2"]]
  },
  {
    "id": "func_door_status",
    "type": "function",
    "z": "tab_esp32_iot",
    "name": "Process Door Status",
    "func": "var status = msg.payload;\nif (status === 'LOCKED') {\n  msg.payload = '🔴 CỬA KHÓA';\n  msg.color = 'red';\n} else if (status === 'OPEN') {\n  msg.payload = '🟢 CỬA MỞ';\n  msg.color = 'green';\n} else {\n  msg.payload = '🟡 CỬA ĐÓNG';\n  msg.color = 'blue';\n}\nreturn msg;",
    "outputs": 1,
    "x": 360, "y": 360,
    "wires": [["ui_text_door_status"]]
  },
  {
    "id": "func_led1_state",
    "type": "function",
    "z": "tab_esp32_iot",
    "name": "Process LED1 State",
    "func": "if (msg.payload === 'ON') {\n  msg.payload = '💡 LED1: BẬT';\n} else {\n  msg.payload = '⚫ LED1: TẮT';\n}\nreturn msg;",
    "outputs": 1,
    "x": 360, "y": 360,
    "wires": [["ui_text_led1_state"]]
  },
  {
    "id": "func_led2_state",
    "type": "function",
    "z": "tab_esp32_iot",
    "name": "Process LED2 State",
    "func": "if (msg.payload === 'ON') {\n  msg.payload = '💡 LED2: BẬT';\n} else {\n  msg.payload = '⚫ LED2: TẮT';\n}\nreturn msg;",
    "outputs": 1,
    "x": 360, "y": 390,
    "wires": [["ui_text_led2_state"]]
  },
  {
    "id": "func_lock_mode",
    "type": "function",
    "z": "tab_esp32_iot",
    "name": "Process Lock Mode",
    "func": "if (msg.payload === 'ON') {\n  msg.payload = '🔒 KÍCH HOẠT';\n} else {\n  msg.payload = '🔓 TẮT';\n}\nreturn msg;",
    "outputs": 1,
    "x": 360, "y": 450,
    "wires": [["ui_text_lock_mode"]]
  },
  {
    "id": "func_vol_mode",
    "type": "function",
    "z": "tab_esp32_iot",
    "name": "Process Volume Mode",
    "func": "if (msg.payload === 'ON') {\n  msg.payload = '🟢 KÍCH HOẠT';\n} else {\n  msg.payload = '🔴 TẮT';\n}\nreturn msg;",
    "outputs": 1,
    "x": 360, "y": 420,
    "wires": [["ui_text_vol_mode"]]
  },
  {
    "id": "func_status_alert",
    "type": "function",
    "z": "tab_esp32_iot",
    "name": "Status Alert",
    "func": "if (msg.payload === 'offline') {\n  node.warn('ESP32 đã mất kết nối!');\n  msg.payload = '🔴 ESP32 OFFLINE';\n} else {\n  msg.payload = '🟢 ESP32 ONLINE';\n}\nreturn msg;",
    "outputs": 1,
    "x": 360, "y": 480,
    "wires": [["ui_text_device_status"]]
  },
  {
    "id": "func_auto_alert",
    "type": "function",
    "z": "tab_esp32_iot",
    "name": "Auto Alert",
    "func": "if (msg.alert && msg.alert !== '') {\n  node.warn(msg.alert + ' (' + msg.payload + 'cm)');\n}\nreturn null;",
    "outputs": 1,
    "x": 560, "y": 80,
    "wires": [[]]
  },


